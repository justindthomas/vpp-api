            {
                "crc": "0x66c8cf1c",
                "options": {},
                "comment": "/** Add or remove an interface from a named zone. The zone is\n * created on first use (sfw_zone_find_or_create) when is_add=true.\n * On is_add=false the interface is removed from its current zone\n * (no-op if it wasn't in one).\n */"
            }
