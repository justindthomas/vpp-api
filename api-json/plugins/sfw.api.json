            ],
            {
                "crc": "0xbb931f93",
                "options": {},
                "comment": "/** Create or delete a policy.\n *\n * On is_add=true: creates a new policy with the given zones and\n * default action. The policy is wired into the zone-pair table\n * and the feature arc is enabled on every interface already in\n * either zone. Zones are created if they don't already exist.\n * Returns an error if a policy with the same name already exists.\n *\n * On is_add=false: detaches the policy from the zone-pair table,\n * frees its rules, and removes it. Only policy_name is consulted.\n *\n * default_action values: 0=deny 1=permit 2=permit-stateful\n *                        3=permit-stateful-nat\n */"
            }
        ],
